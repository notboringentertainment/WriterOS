    "@tiptap/extension-paragraph": "^3.22.5",
    "@tiptap/extension-text": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "openai": "^5.20.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "4.17.21",
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.11",
